generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CANDIDATE
  COMPANY
  ADMIN
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  REJECTED
  HIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum JobStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum CompanyStatus {
  PENDING
  APPROVED
  SUSPENDED
}

model User {
  id                String        @id @default(cuid())
  email             String        @unique
  password          String
  role              UserRole      @default(CANDIDATE)
  name              String
  mobile            String?
  isBlocked         Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  candidate         Candidate?
  company           Company?
  sessions          Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Candidate {
  id                String    @id @default(cuid())
  userId            String    @unique
  location          String?
  experience        Int       @default(0)
  qualification     String?
  currentRole       String?
  expectedSalary    Int?
  summary           String?
  resumeUrl         String?
  profileViews      Int       @default(0)
  profileCompletion Int       @default(0)
  paymentStatus     String    @default("pending")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills            CandidateSkill[]
  applications      Application[]
  payments          Payment[]
  savedJobs         SavedJob[]

  @@map("candidates")
}

model CandidateSkill {
  id          String    @id @default(cuid())
  candidateId String
  skill       String
  level       String    @default("intermediate")

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, skill])
  @@map("candidate_skills")
}

model Company {
  id          String        @id @default(cuid())
  userId      String        @unique
  name        String
  hrName      String?
  industry    String?
  size        String?
  location    String?
  address     String?
  description String?
  website     String?
  logoColor   String        @default("#4f46e5")
  logoText    String?
  isVerified  Boolean       @default(false)
  status      CompanyStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs        Job[]

  @@map("companies")
}

model Job {
  id           String      @id @default(cuid())
  companyId    String
  title        String
  description  String
  location     String?
  isRemote     Boolean     @default(false)
  type         String      @default("Full-time")
  experience   String?
  salaryMin    Int?
  salaryMax    Int?
  category     String?
  contactEmail String?
  deadline     DateTime?
  status       JobStatus   @default(ACTIVE)
  isFlagged    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skills       JobSkill[]
  applications Application[]
  savedBy      SavedJob[]

  @@map("jobs")
}

model JobSkill {
  id    String @id @default(cuid())
  jobId String
  skill String

  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, skill])
  @@map("job_skills")
}

model Application {
  id          String            @id @default(cuid())
  candidateId String
  jobId       String
  status      ApplicationStatus @default(PENDING)
  coverNote   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  candidate   Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobId])
  @@map("applications")
}

model Payment {
  id            String        @id @default(cuid())
  candidateId   String
  amount        Int           @default(100)
  status        PaymentStatus @default(PENDING)
  method        String?
  transactionId String?       @unique
  receiptUrl    String?
  createdAt     DateTime      @default(now())

  candidate     Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model SavedJob {
  id          String    @id @default(cuid())
  candidateId String
  jobId       String
  createdAt   DateTime  @default(now())

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobId])
  @@map("saved_jobs")
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, type])
  @@map("otp_codes")
}
